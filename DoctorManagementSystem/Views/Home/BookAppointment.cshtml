@model IEnumerable<Doctor>

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-primary">Find Your Specialist</h1>
        <p class="lead text-muted">Search from our certified doctors and book your slot in seconds.</p>
    </div>

    <div class="row justify-content-center mb-5">
        <div class="col-md-6">
            <div class="card border-0 shadow-sm p-4 bg-light">
                <form  method="get" class="d-flex gap-2">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="bi bi-search text-muted"></i>
                        </span>
                        <input type="text" 
                               class="form-control border-start-0 ps-0" 
                               name="Name" 
                               placeholder="Type doctor's name..."
                               value=""
                               required>
                    </div>
                    <button type="submit" class="btn btn-primary px-4">Search</button>
                </form>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-person-x fs-1 text-muted"></i>
                <h3 class="mt-3 text-muted">No doctors found matching your search.</h3>
                <a asp-action="Index" class="btn btn-link">View all doctors</a>
            </div>
        }
        else
        {
            @foreach (var item in Model)
            {
                <div class="col-sm-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm hover-shadow transition">
                        
                        @* Added bg-white and border-bottom for a clean separation *@
                        <div class="position-relative overflow-hidden bg-white border-bottom" style="height: 280px; display: flex; align-items: center; justify-content: center;">
                            <img class="card-img-top"
                                 src="~/Image/doctor@(item.Img)"
                                 alt="Dr. @item.Name"
                                 @* object-fit: contain ensures the image is never cut *@
                                 style="max-height: 100%; max-width: 100%; width: auto; object-fit: contain;">
                            
                            @* Optional: Availability badge *@
                            <div class="position-absolute top-0 end-0 m-2">
                                <span class="badge bg-success rounded-pill px-3 py-2">Available</span>
                            </div>
                        </div>

                        <div class="card-body text-center d-flex flex-column p-4">
                            <h5 class="card-title fw-bold mb-1">Dr. @item.Name</h5>
                            <p class="text-primary small mb-3 fw-semibold text-uppercase tracking-wider">
                                @item.Specialization
                            </p>
                            
                            <div class="mt-auto d-grid">
                                <a asp-controller="Home" 
                                   asp-action="CompleteAppointment" 
                                   asp-route-id="@item.Id" 
                                   class="btn btn-outline-primary rounded-pill py-2">
                                   Book Appointment
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    /* Smooth Hover Effect */
    .hover-shadow {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .hover-shadow:hover {
        transform: translateY(-8px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.1) !important;
    }
    .tracking-wider { letter-spacing: 1px; }
</style>